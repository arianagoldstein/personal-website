{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "npm run lint --if-present 2>/dev/null || true",
            "statusMessage": "Linting..."
          }
        ]
      }
    ]
  }
}
